---
import Layout from "../../layouts/Layout.astro";
import NavBar from "../../components/NavBar.astro";
import Footer from "../../components/Footer.astro";
import Whatsapp from "../../components/Whatsapp.astro";
import FormProgress from "../../components/FormProgress.astro";
---

<Layout title="Formulario Aspirantes – Previo a Entrevista">
  <NavBar />
  <div class="h-20 bg-black"></div>

  <form
    id="jobForm"
    method="post"
    class="bg-gray-50 p-6 rounded-2xl border border-gray-200 m-10"
  >
    <div id="formStatus" class="status-box hidden" role="status" aria-live="polite">
    </div>

    <!-- Paso 1 -->
    <div
      id="step1"
      class="step max-w-2xl mx-auto bg-white p-8 rounded-2xl shadow-lg"
    >
      <FormProgress step="1" />

      <h2 class="text-3xl font-bold text-emerald-700 mb-2">
        Asesores Comerciales para el Valle y el Sur de Quito 
      </h2>
      <p class="text-gray-500 mb-8 text-sm">
        Completa tus datos personales para continuar con el proceso.
      </p>

      <!-- 1. Datos personales -->
      <section class="form-section">
        <h3>1. Datos personales</h3>

        <div class="mt-5">
          <label for="nombreCompleto" class="label">Nombre completo</label>
          <input
            id="nombreCompleto"
            name="nombreCompleto"
            class="input"
            type="text"
          />
        </div>

        <div>
          <label for="cedula" class="label">Número de cédula</label>
          <input id="cedula" name="cedula" class="input" />
        </div>

        <div class="mt-5">
          <label for="telefono" class="label">Telefono</label>
          <input
            id="telefono"
            name="telefono"
            class="input"
            type="tel"
          />
        </div>

        <div class="mt-5">
          <label for="edadCumplida" class="label">Edad cumplida</label>
          <input
            id="edadCumplida"
            name="edadCumplida"
            class="input"
            type="number"
            min="0"
          />
        </div>

        <div class="mt-5">
          <label for="numeroHijos" class="label">Numero de hijos</label>
          <input
            id="numeroHijos"
            name="numeroHijos"
            class="input"
            type="number"
            min="0"
          />
        </div>

        <div class="mt-8">
          <p class="label mb-3">Estado civil</p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <label class="radio-card">
              <input type="radio" name="estadoCivil" value="Soltero" class="sr-only" />
              <span>Soltero</span>
            </label>

            <label class="radio-card">
              <input type="radio" name="estadoCivil" value="Casado" class="sr-only" />
              <span>Casado</span>
            </label>

            <label class="radio-card">
              <input type="radio" name="estadoCivil" value="Union libre" class="sr-only" />
              <span>Union libre</span>
            </label>

            <label class="radio-card">
              <input type="radio" name="estadoCivil" value="Separado" class="sr-only" />
              <span>Separado</span>
            </label>

            <label class="radio-card">
              <input type="radio" name="estadoCivil" value="Divorciado" class="sr-only" />
              <span>Divorciado</span>
            </label>
          </div>
        </div>

        <div class="mt-8">
          <p class="label mb-3">Ciudad de nacimiento</p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <label class="radio-card">
              <input
                type="radio"
                name="ciudadNacimiento"
                value="Quito"
                class="sr-only"
              />
              <span>Quito</span>
            </label>

            <label class="radio-card">
              <input
                type="radio"
                name="ciudadNacimiento"
                value="Otra"
                class="sr-only"
              />
              <span>Otra</span>
            </label>
          </div>

          <p id="quitoSkipNotice" class="helper mt-3 hidden">
            Si naciste en Quito, pasa directamente a la seccion 2, en Informacion de Vivienda actual.
          </p>

          <div id="otraCiudadNacimientoWrap" class="mt-5 hidden">
            <label for="otraCiudadNacimiento" class="label">
              Otra ciudad
            </label>
            <input
              id="otraCiudadNacimiento"
              name="otraCiudadNacimiento"
              class="input"
              type="text"
              placeholder="Especifique ciudad"
            />
          </div>
        </div>

        <div class="mt-5">
          <label for="direccion" class="label">Direccion</label>
          <input
            id="direccion"
            name="direccion"
            class="input"
            type="text"
            placeholder="Ingrese su direccion actual"
          />
        </div>
      </section>

      <!-- 2. Residencia en Quito -->
      <section id="residenciaQuitoSection" class="form-section mt-10">
        <h3>2. Residencia en Quito</h3>

        <p class="helper mt-2">
          En caso de ser quiteño/a de nacimiento, no llenar esta sección.
        </p>

        <div class="mt-5">
          <label for="tiempoResidenciaQuito" class="label">
            ¿Hace qué tiempo reside en Quito?
          </label>
          <input
            id="tiempoResidenciaQuito"
            name="tiempoResidenciaQuito"
            class="input"
            type="text"
            placeholder="Ej: 2 años, 6 meses"
          />
        </div>

        <div class="mt-5">
          <label for="motivoSalidaCiudadNatal" class="label">
            Motivo de salida de su ciudad natal
          </label>
          <p class="helper">Sea específico/a.</p>
          <textarea
            id="motivoSalidaCiudadNatal"
            name="motivoSalidaCiudadNatal"
            class="input"
            style="min-height: 140px"></textarea>
        </div>
      </section>

      <div class="mt-10 flex justify-end">
        <button type="button" id="nextStep1" class="btn-primary">
          Continuar
        </button>
      </div>
    </div>

    <!-- Paso 2 -->
    <div id="step2" class="step hidden">
      <FormProgress step="2" />

      <!-- 3. Información de vivienda actual -->
      <section class="form-section">
        <h2>Información de vivienda actual</h2>

        <p class="helper mt-2">
          Esta sección debe ser llenada por todos los aspirantes.
        </p>

        <div class="mt-8">
          <p class="label mb-3">La vivienda en que actualmente reside es:</p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
            <label class="radio-card">
              <input
                type="radio"
                name="tipoVivienda"
                value="Familiar"
                class="sr-only"
              />
              <span>Familiar</span>
            </label>

            <label class="radio-card">
              <input
                type="radio"
                name="tipoVivienda"
                value="Arrendada"
                class="sr-only"
              />
              <span>Arrendada</span>
            </label>

            <label class="radio-card">
              <input
                type="radio"
                name="tipoVivienda"
                value="Prestada"
                class="sr-only"
              />
              <span>Prestada</span>
            </label>

            <label class="radio-card">
              <input
                type="radio"
                name="tipoVivienda"
                value="Propia"
                class="sr-only"
              />
              <span>Propia</span>
            </label>

            <label class="radio-card sm:col-span-2">
              <input
                type="radio"
                name="tipoVivienda"
                value="Otra"
                class="sr-only"
              />
              <span>Otra</span>
            </label>
          </div>

          <div class="mt-5">
            <label for="viviendaFamiliarQuien" class="label">
              Si es familiar, especifique quién
            </label>
            <input
              id="viviendaFamiliarQuien"
              name="viviendaFamiliarQuien"
              class="input"
              type="text"
            />
          </div>
        </div>
      </section>

      <!-- 4. Grupo familiar -->
      <section class="form-section mt-10">
        <h2>Grupo familiar / personas con quienes vive</h2>

        <p class="label mt-5">¿Con quién vive actualmente?</p>

        <div class="family-grid mt-4">
          {
            [1, 2, 3, 4, 5].map((i) => (
              <div class="family-card">
                <p class="family-card-title">Persona {i}</p>

                <div class="family-fields">
                  <div>
                    <label class="label" for={`convive${i}_nombre`}>Nombre</label>
                    <input id={`convive${i}_nombre`} class="input" name={`convive${i}_nombre`} type="text" />
                  </div>

                  <div>
                    <label class="label" for={`convive${i}_telefono`}>Telefono</label>
                    <input id={`convive${i}_telefono`} class="input" name={`convive${i}_telefono`} type="tel" />
                  </div>

                  <div>
                    <label class="label" for={`convive${i}_pariente`}>Pariente</label>
                    <input id={`convive${i}_pariente`} class="input" name={`convive${i}_pariente`} type="text" />
                  </div>

                  <div>
                    <label class="label" for={`convive${i}_edad`}>Edad</label>
                    <input id={`convive${i}_edad`} class="input" name={`convive${i}_edad`} type="number" min="0" />
                  </div>

                  <div>
                    <label class="label" for={`convive${i}_ocupacion`}>Ocupacion</label>
                    <input id={`convive${i}_ocupacion`} class="input" name={`convive${i}_ocupacion`} type="text" />
                  </div>

                  <div>
                    <label class="label" for={`convive${i}_tituloProfesion`}>Titulo o Profesion</label>
                    <input id={`convive${i}_tituloProfesion`} class="input" name={`convive${i}_tituloProfesion`} type="text" />
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <div class="mt-10 flex justify-between">
        <button type="button" id="backStep2" class="btn-secondary">
          Regresar
        </button>

        <button type="button" id="nextStep2" class="btn-primary">
          Continuar
        </button>
      </div>
    </div>

    <!-- Paso 3 -->
    <div id="step3" class="step hidden">
      <FormProgress step="3" />

      <!-- 5. Historial laboral -->
      <section class="form-section">
        <h2>Historial laboral</h2>

        <div class="note-box mt-5">
          <p class="font-semibold text-gray-800">Nota importante:</p>

          <p class="mt-2">
            Esta sección debe ser llenada con todos los datos de todos sus
            trabajos y extrabajos, sean anteriores o actuales.
          </p>

          <p class="mt-2">Puede ser desde un día en adelante.</p>

          <p class="mt-2">No importa si fue formal o informal.</p>

          <p class="mt-2 font-semibold text-emerald-700">
            Debe registrar toda actividad laboral que haya realizado.
          </p>
        </div>

        <div class="work-grid mt-6">
          {
            [1, 2, 3, 4, 5].map((i) => (
              <div class="work-card">
                <p class="work-card-title">Trabajo {i}</p>

                <div class="work-fields">
                  <div>
                    <label class="label" for={`trabajo${i}_empresa`}>Empresa / Lugar de trabajo</label>
                    <input id={`trabajo${i}_empresa`} class="input" name={`trabajo${i}_empresa`} type="text" />
                  </div>

                  <div>
                    <label class="label" for={`trabajo${i}_cargoActividad`}>Cargo / Actividad realizada</label>
                    <input id={`trabajo${i}_cargoActividad`} class="input" name={`trabajo${i}_cargoActividad`} type="text" />
                  </div>

                  <div>
                    <label class="label" for={`trabajo${i}_tiempoTrabajado`}>Tiempo trabajado</label>
                    <input id={`trabajo${i}_tiempoTrabajado`} class="input" name={`trabajo${i}_tiempoTrabajado`} type="text" />
                  </div>

                  <div>
                    <label class="label" for={`trabajo${i}_motivoSalida`}>Motivo de salida</label>
                    <input id={`trabajo${i}_motivoSalida`} class="input" name={`trabajo${i}_motivoSalida`} type="text" />
                  </div>

                  <div>
                    <label class="label" for={`trabajo${i}_jefeEncargado`}>Nombre del jefe o encargado</label>
                    <input id={`trabajo${i}_jefeEncargado`} class="input" name={`trabajo${i}_jefeEncargado`} type="text" />
                  </div>

                  <div>
                    <label class="label" for={`trabajo${i}_telefonoReferencia`}>Telefono de referencia</label>
                    <input id={`trabajo${i}_telefonoReferencia`} class="input" name={`trabajo${i}_telefonoReferencia`} type="tel" />
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </section>

      <!-- 6. Observaciones adicionales -->
      <section class="form-section mt-10">
        <h2>Observaciones adicionales</h2>

        <div class="mt-5">
          <label for="logrosVida" class="label">
            Que logros a alcanzado en su vida
          </label>
          <textarea
            id="logrosVida"
            name="logrosVida"
            class="input"
            style="min-height: 140px"></textarea>
        </div>

        <div class="mt-5">
          <label for="observacionesAdicionales" class="label">
            Escriba cualquier información adicional relevante
          </label>
          <textarea
            id="observacionesAdicionales"
            name="observacionesAdicionales"
            class="input"
            style="min-height: 140px"></textarea>
        </div>

      </section>

      <div class="mt-10 flex justify-between">
        <button type="button" id="backStep3" class="btn-secondary">
          Regresar
        </button>

        <button type="submit" class="btn-primary"> Enviar formulario </button>
      </div>
    </div>
  </form>

  <Whatsapp />
  <Footer />
</Layout>

<style>
  /* ===== CONTENEDOR STEP ===== */
  .step {
    max-width: 920px;
    margin: 0 auto;
    background: #ffffff;
    padding: 2.5rem;
    border-radius: 1.25rem;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
  }

  /* ===== SECCIONES ===== */
  .form-section {
    border-bottom: 1px solid #e5e7eb;
    padding-bottom: 2rem;
  }

  .form-section:last-child {
    border-bottom: none;
  }

  /* ===== TEXTOS ===== */
  h2 {
    font-size: 1.75rem;
    font-weight: 700;
    color: #047857;
  }

  h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #047857;
  }

  p {
    color: #6b7280;
    font-size: 0.875rem;
  }

  /* ===== LABELS ===== */
  .label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: #374151;
    margin-bottom: 0.25rem;
  }

  .helper {
    font-size: 0.8rem;
    color: #6b7280;
    margin-top: 0.25rem;
  }

  /* ===== INPUTS ===== */
  .input {
    width: 100%;
    padding: 0.75rem 1rem;
    border-radius: 0.75rem;
    border: 1px solid #d1d5db;
    font-size: 0.95rem;
    transition: all 0.2s ease;
    background: #ffffff;
  }

  .input:focus,
  .table-input:focus {
    outline: none;
    border-color: #10b981;
    box-shadow: 0 0 0 3px rgba(16, 185, 129, 0.25);
  }

  textarea.input {
    resize: vertical;
  }

  /* ===== GRID UTILITIES ===== */
  .grid {
    display: grid;
    gap: 1rem;
  }

  .grid-2 {
    grid-template-columns: repeat(2, 1fr);
  }

  .grid-3 {
    grid-template-columns: repeat(3, 1fr);
  }

  @media (max-width: 640px) {
    .grid-2,
    .grid-3 {
      grid-template-columns: 1fr;
    }
  }

  /* ===== RADIO CARD ===== */
  .radio-card {
    cursor: pointer;
    border: 1px solid #d1d5db;
    border-radius: 0.75rem;
    padding: 0.75rem;
    text-align: center;
    font-weight: 500;
    color: #374151;
    transition: all 0.2s ease;
    user-select: none;
    background: #ffffff;
  }

  .radio-card:hover {
    border-color: #10b981;
  }

  .radio-card input {
    display: none;
  }

  .radio-card:has(input:checked) {
    border-color: #059669;
    background-color: #ecfdf5;
    color: #047857;
  }

  /* ===== TABLAS ===== */
  .table-wrapper {
    width: 100%;
    overflow-x: auto;
    border: 1px solid #e5e7eb;
    border-radius: 1rem;
    background: #ffffff;
  }

  .form-table {
    width: 100%;
    min-width: 900px;
    border-collapse: collapse;
  }

  .form-table th {
    background: #ecfdf5;
    color: #047857;
    font-size: 0.8rem;
    font-weight: 700;
    text-align: left;
    padding: 0.85rem;
    border-bottom: 1px solid #d1fae5;
  }

  .form-table td {
    padding: 0.5rem;
    border-bottom: 1px solid #e5e7eb;
    border-right: 1px solid #e5e7eb;
  }

  .form-table tr:last-child td {
    border-bottom: none;
  }

  .form-table td:last-child {
    border-right: none;
  }

  .table-input {
    width: 100%;
    min-width: 120px;
    padding: 0.6rem 0.7rem;
    border-radius: 0.5rem;
    border: 1px solid #d1d5db;
    font-size: 0.875rem;
    background: #ffffff;
  }

  .family-grid,
  .work-grid {
    display: grid;
    gap: 1rem;
  }

  .family-card,
  .work-card {
    border: 1px solid #e5e7eb;
    border-radius: 1rem;
    background: #ffffff;
    padding: 1rem;
  }

  .family-card-title,
  .work-card-title {
    margin-bottom: 1rem;
    font-size: 0.9rem;
    font-weight: 700;
    color: #047857;
  }

  .family-fields,
  .work-fields {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  @media (max-width: 640px) {
    .family-fields,
    .work-fields {
      grid-template-columns: 1fr;
    }
  }

  .status-box {
    max-width: 920px;
    margin: 0 auto 1rem;
    border-radius: 0.75rem;
    padding: 0.9rem 1rem;
    border: 1px solid transparent;
    font-size: 0.95rem;
    font-weight: 600;
  }

  .status-box.success {
    background: #ecfdf5;
    border-color: #a7f3d0;
    color: #047857;
  }

  .status-box.error {
    background: #fef2f2;
    border-color: #fecaca;
    color: #b91c1c;
  }

  .field-error {
    border-color: #ef4444 !important;
    box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.18) !important;
  }

  /* ===== NOTA ===== */
  .note-box {
    background: #f9fafb;
    border: 1px solid #e5e7eb;
    border-radius: 1rem;
    padding: 1.25rem;
  }

  /* ===== BOTONES ===== */
  .btn-primary {
    background-color: #059669;
    color: #ffffff;
    padding: 0.75rem 2rem;
    border-radius: 0.75rem;
    border: none;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      transform 0.1s ease;
  }

  .btn-primary:hover {
    background-color: #047857;
  }

  .btn-primary:active {
    transform: scale(0.97);
  }

  .btn-secondary {
    background-color: #f3f4f6;
    color: #374151;
    padding: 0.75rem 1.5rem;
    border-radius: 0.75rem;
    border: 1px solid #d1d5db;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition:
      background-color 0.2s ease,
      transform 0.1s ease;
  }

  .btn-secondary:hover {
    background-color: #e5e7eb;
  }

  .btn-secondary:active {
    transform: scale(0.97);
  }

  @media (max-width: 640px) {
    .step {
      padding: 1.5rem;
    }

    form {
      margin: 1rem !important;
      padding: 1rem !important;
    }
  }
</style>

<script>
  console.log("Script cargado");

  const jobForm = document.getElementById("jobForm") as HTMLFormElement;
  const formStatus = document.getElementById("formStatus") as HTMLDivElement;

  const step1 = document.getElementById("step1") as HTMLDivElement;
  const step2 = document.getElementById("step2") as HTMLDivElement;
  const step3 = document.getElementById("step3") as HTMLDivElement;
  const residenciaQuitoSection = document.getElementById(
    "residenciaQuitoSection",
  ) as HTMLElement | null;
  const otraCiudadNacimientoWrap = document.getElementById(
    "otraCiudadNacimientoWrap",
  ) as HTMLElement | null;
  const quitoSkipNotice = document.getElementById(
    "quitoSkipNotice",
  ) as HTMLElement | null;

  const nextStep1Btn = document.getElementById(
    "nextStep1",
  ) as HTMLButtonElement;

  const nextStep2Btn = document.getElementById(
    "nextStep2",
  ) as HTMLButtonElement;

  const backStep2Btn = document.getElementById(
    "backStep2",
  ) as HTMLButtonElement;

  const backStep3Btn = document.getElementById(
    "backStep3",
  ) as HTMLButtonElement;

  const showStep = (step: number) => {
    step1.classList.toggle("hidden", step !== 1);
    step2.classList.toggle("hidden", step !== 2);
    step3.classList.toggle("hidden", step !== 3);
    window.scrollTo({ top: 0, behavior: "smooth" });
  };

  const getValue = (name: string) => {
    const field = jobForm.elements.namedItem(name) as
      | HTMLInputElement
      | HTMLTextAreaElement
      | null;

    return field?.value?.trim() || "";
  };

  const getCheckedValue = (name: string) => {
    const field = jobForm.querySelector(
      `input[name="${name}"]:checked`,
    ) as HTMLInputElement | null;

    return field?.value || "";
  };

  const updateCiudadNacimientoView = () => {
    const ciudadNacimiento = getCheckedValue("ciudadNacimiento");
    const esQuito = ciudadNacimiento === "Quito";
    const esOtra = ciudadNacimiento === "Otra";

    quitoSkipNotice?.classList.toggle("hidden", !esQuito);
    otraCiudadNacimientoWrap?.classList.toggle("hidden", !esOtra);
    residenciaQuitoSection?.classList.toggle("hidden", esQuito);

    if (!esOtra) {
      const otraCiudad = jobForm.elements.namedItem(
        "otraCiudadNacimiento",
      ) as HTMLInputElement | null;
      if (otraCiudad) otraCiudad.value = "";
    }

    if (esQuito) {
      const tiempoResidencia = jobForm.elements.namedItem(
        "tiempoResidenciaQuito",
      ) as HTMLInputElement | null;
      const motivoSalida = jobForm.elements.namedItem(
        "motivoSalidaCiudadNatal",
      ) as HTMLTextAreaElement | null;

      if (tiempoResidencia) tiempoResidencia.value = "";
      if (motivoSalida) motivoSalida.value = "";
    }
  };

  const clearStatus = () => {
    formStatus.textContent = "";
    formStatus.className = "status-box hidden";
  };

  const showStatus = (message: string, type: "success" | "error") => {
    formStatus.textContent = message;
    formStatus.className = `status-box ${type}`;
    formStatus.scrollIntoView({ behavior: "smooth", block: "center" });
  };

  const clearErrors = () => {
    jobForm
      .querySelectorAll(".field-error")
      .forEach((field) => field.classList.remove("field-error"));
  };

  const markField = (name: string) => {
    if (!name) return;
    const field = jobForm.elements.namedItem(name) as HTMLElement | null;
    field?.classList.add("field-error");
  };

  const hasData = (obj: Record<string, string>) =>
    Object.values(obj).some((value) => value !== "");

  const validateStep = (step: number) => {
    clearErrors();

    if (step === 1) {
      const missing = [];

      if (!getValue("nombreCompleto")) {
        missing.push("nombre completo");
        markField("nombreCompleto");
      }

      if (!getValue("cedula")) {
        missing.push("cedula");
        markField("cedula");
      }

      if (!getValue("edadCumplida")) {
        missing.push("edad cumplida");
        markField("edadCumplida");
      }

      if (!getCheckedValue("ciudadNacimiento")) {
        missing.push("ciudad de nacimiento");
      }

      if (
        getCheckedValue("ciudadNacimiento") === "Otra" &&
        !getValue("otraCiudadNacimiento")
      ) {
        missing.push("otra ciudad de nacimiento");
        markField("otraCiudadNacimiento");
      }

      if (missing.length) {
        showStatus(`Completa estos campos: ${missing.join(", ")}.`, "error");
        return false;
      }
    }

    if (step === 2 && !getCheckedValue("tipoVivienda")) {
      showStatus("Selecciona el tipo de vivienda actual.", "error");
      return false;
    }

    clearStatus();
    return true;
  };

  const buildPayload = () => {
    const personas_con_quien_vive = [1, 2, 3, 4, 5]
      .map((i) => ({
        nombre: getValue(`convive${i}_nombre`),
        telefono: getValue(`convive${i}_telefono`),
        pariente: getValue(`convive${i}_pariente`),
        edad: getValue(`convive${i}_edad`),
        ocupacion: getValue(`convive${i}_ocupacion`),
        tituloProfesion: getValue(`convive${i}_tituloProfesion`),
      }))
      .filter(hasData);

    const historial_laboral = [1, 2, 3, 4, 5]
      .map((i) => ({
        empresaLugarTrabajo: getValue(`trabajo${i}_empresa`),
        cargoActividadRealizada: getValue(`trabajo${i}_cargoActividad`),
        tiempoTrabajado: getValue(`trabajo${i}_tiempoTrabajado`),
        motivoSalida: getValue(`trabajo${i}_motivoSalida`),
        jefeEncargado: getValue(`trabajo${i}_jefeEncargado`),
        telefonoReferencia: getValue(`trabajo${i}_telefonoReferencia`),
      }))
      .filter(hasData);

    return {
      datos_personales: {
        nombreCompleto: getValue("nombreCompleto"),
        cedula: getValue("cedula"),
        telefono: getValue("telefono"),
        edadCumplida: getValue("edadCumplida"),
        numeroHijos: getValue("numeroHijos"),
        estadoCivil: getCheckedValue("estadoCivil"),
        ciudadNacimiento: getCheckedValue("ciudadNacimiento"),
        otraCiudadNacimiento: getValue("otraCiudadNacimiento"),
        direccion: getValue("direccion"),
      },
      residencia_quito: {
        tiempoResidenciaQuito: getValue("tiempoResidenciaQuito"),
        motivoSalidaCiudadNatal: getValue("motivoSalidaCiudadNatal"),
      },
      vivienda_actual: {
        tipoVivienda: getCheckedValue("tipoVivienda"),
        viviendaFamiliarQuien: getValue("viviendaFamiliarQuien"),
      },
      personas_con_quien_vive,
      historial_laboral,
      observaciones: {
        logrosVida: getValue("logrosVida"),
        observacionesAdicionales: getValue("observacionesAdicionales"),
      },
    };
  };

  jobForm
    .querySelectorAll('input[name="ciudadNacimiento"]')
    .forEach((field) => field.addEventListener("change", updateCiudadNacimientoView));

  updateCiudadNacimientoView();

  nextStep1Btn?.addEventListener("click", () => {
    if (validateStep(1)) showStep(2);
  });

  nextStep2Btn?.addEventListener("click", () => {
    if (validateStep(2)) showStep(3);
  });

  backStep2Btn?.addEventListener("click", () => {
    clearStatus();
    showStep(1);
  });

  backStep3Btn?.addEventListener("click", () => {
    clearStatus();
    showStep(2);
  });

  jobForm.addEventListener("submit", async (e) => {
    e.preventDefault();

    if (!validateStep(1)) return showStep(1);
    if (!validateStep(2)) return showStep(2);
    if (!validateStep(3)) return;

    const submitBtn = jobForm.querySelector(
      'button[type="submit"]',
    ) as HTMLButtonElement;

    if (!submitBtn) return;

    submitBtn.disabled = true;
    submitBtn.textContent = "Enviando...";
    clearStatus();

    try {
      const res = await fetch(
     `https://apiapolo.creditek-ecuador.com/api/postulaciones`,
      // `http://localhost:5030/api/postulaciones`,
        {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(buildPayload()),
        },
      );

      const result = await res.json();

      if (res.ok) {
        jobForm.reset();
        sessionStorage.setItem(
          "postulacionStatus",
          "Gracias por llenar la encuesta.",
        );
        window.location.href = "/trabaja-con-nosotros";
      } else {
        showStatus(result.message || "Error al enviar. Intenta de nuevo.", "error");
      }
    } catch (err) {
      console.error("Error:", err);
      showStatus("Error de conexion. Por favor intenta de nuevo.", "error");
    } finally {
      submitBtn.disabled = false;
      submitBtn.textContent = "Enviar formulario";
    }
  });
</script>
